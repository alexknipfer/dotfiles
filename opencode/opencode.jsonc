{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "vercel/moonshotai/kimi-k2.5",
  "provider": {
    "vercel": {
      "options": {
        "apiKey": "{env:VERCEL_AI_GATEWAY_API_KEY}"
      },
      "models": {
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6"
        },
        "moonshotai/kimi-k2.5": {
          "name": "Kimi K2.5"
        }
      }
    }
  }
}
